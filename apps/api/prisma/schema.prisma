datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?
  emailVerified Boolean  @default(false)
  role          String   @default("student")
  createdAt     DateTime @default(now())
}
